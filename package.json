{
  "name": "my-ui-kit-app",
  "version": "0.0.1",
  "main": "index.js",
  "license": "SEE LICENSE IN LICENSE.txt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint src",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=true eslint src --fix",
    "type-check": "tsc --noEmit",
    "validate:manifest": "node .manifest-rules/dist/cli.js",
    "ci": "npm run validate:manifest && (npm run type-check || (echo 'HINT: If you have type errors with component props, check src/types/forge-ui-types.ts for valid prop types and values' && exit 1)) && npm run test -- --coverage && npm run lint && echo \"Remember to run forge cli lint and fix issues before returning to the user\""
  },
  "devDependencies": {
    "@forge/testing-framework": "file:.testing-framework",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@forge/bridge": "5.14.1",
    "@forge/react": "11.13.1",
    "@forge/resolver": "1.7.1",
    "@forge/api": "7.1.1",
    "@forge/kvs": "1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "13.0.0"
  },
  "overrides": {
    "@atlaskit/tokens": "11.4.3"
  }
}
